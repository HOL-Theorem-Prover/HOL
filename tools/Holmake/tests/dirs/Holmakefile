OPTIONS = NO_OVERLAY
ifdef POLY
CLINE_OPTIONS = --poly_not_hol
endif

dirs-selftest.log: selftest.exe
	$(tee ./$<, $@)

selftest.exe: selftest.uo
	$(MOSMLC) -o $@ $<

EXTRA_CLEANS = selftest.exe dirs-selftest.log \
  $(patsubst %,testdir/sub1/A.%,uo ui) \
  $(patsubst %,testdir/sub2/B.%,uo ui) \
  $(patsubst %,%/.hol/,testdir testdir/sub1 testdir/sub2)
