OPTIONS = NO_OVERLAY

INCLUDES = $(HOLDIR)/tools/Holmake/core \
           $(HOLDIR)/tools/Holmake/toml

EXTRA_CLEANS = h4pedant

.PHONY: all
all: h4pedant

ifdef POLY

h4pedant: poly-h4pedant.ML h4pedant.sml h4pedantConfig.sml
	$(POLYC) $< -o $@

else

h4pedant: h4pedant_mosml.uo h4pedantConfig.uo h4pedant.uo
	$(MOSMLC) -o $@ $<

endif
