#|
Original definition:

   ⊢ (∀ord. QSORT ord [] = []) ∧
     ∀t ord h.
       QSORT ord (h::t) =
       (let
          (l1,l2) = PARTITION (λy. ord y h) t
        in
          QSORT ord l1 ⧺ [h] ⧺ QSORT ord l2)

Auxiliary definitions:

   ⊢ ∀ord h y. Lam_29 ord h y ⇔ ord y h

Auxiliary definitions (pseudo recursive):

   ⊢ ∀ord h l1 l2. Lam_28 ord h l1 l2 = QSORT ord l1 ⧺ [h] ⧺ QSORT ord l2

Lifted definition:

   ⊢ (∀ord. QSORT ord [] = []) ∧
     ∀t ord h.
       QSORT ord (h::t) =
       LET (UNCURRY (Lam_28 ord h)) (PARTITION (Lam_29 ord h) t)
|#

(defhol
   :fns ((lam_29 (:arrow* (:arrow* a a :bool) a a :bool)))
   :defs ((:forall ((ord (:arrow* a a :bool)) (h a) (y a))
      (equal
       (hap* (lam_29 (typ (:arrow* (:arrow* a a :bool) a a :bool))) ord h y)
       (hap* ord y h)))))

(defhol
   :fns ((lam_28
      (:arrow* (:arrow* a a :bool) a (:list a) (:list a) (:list a)))
     (qsort (:arrow* (:arrow* a a :bool) (:list a) (:list a))))
   :defs ((:forall
      ((ord (:arrow* a a :bool)) (h a) (l1 (:list a)) (l2 (:list a)))
      (equal
       (hap*
        (lam_28
         (typ (:arrow* (:arrow* a a :bool) a (:list a) (:list a) (:list a))))
        ord h l1 l2)
       (hap* (append (typ (:arrow* (:list a) (:list a) (:list a))))
        (hap* (append (typ (:arrow* (:list a) (:list a) (:list a))))
         (hap* (qsort (typ (:arrow* (:arrow* a a :bool) (:list a) (:list a))))
          ord l1) (hp-cons h (hp-nil (typ a))))
        (hap* (qsort (typ (:arrow* (:arrow* a a :bool) (:list a) (:list a))))
         ord l2))))
     (:forall ((ord (:arrow* a a :bool)))
      (equal
       (hap* (qsort (typ (:arrow* (:arrow* a a :bool) (:list a) (:list a))))
        ord (hp-nil (typ a))) (hp-nil (typ a))))
     (:forall ((t (:list a)) (ord (:arrow* a a :bool)) (h a))
      (equal
       (hap* (qsort (typ (:arrow* (:arrow* a a :bool) (:list a) (:list a))))
        ord (hp-cons h t))
       (hap*
        (let
         (typ
          (:arrow* (:arrow* (:hash (:list a) (:list a)) (:list a))
           (:hash (:list a) (:list a)) (:list a))))
        (hap*
         (uncurry
          (typ
           (:arrow* (:arrow* (:list a) (:list a) (:list a))
            (:hash (:list a) (:list a)) (:list a))))
