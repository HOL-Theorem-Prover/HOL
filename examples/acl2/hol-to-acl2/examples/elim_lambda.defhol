#|
Definition:

   ⊢ (∀f. MAP f [] = []) ∧ ∀f h t. MAP f (h::t) = f h::MAP f t
|#

(defhol
   :fns ((map (:arrow* (:arrow* a b) (:list a) (:list b))))
   :defs ((:forall ((f (:arrow* a b)))
      (equal
       (hap* (map (typ (:arrow* (:arrow* a b) (:list a) (:list b)))) f
        (hp-nil (typ a))) (hp-nil (typ b))))
     (:forall ((f (:arrow* a b)) (h a) (t (:list a)))
      (equal
       (hap* (map (typ (:arrow* (:arrow* a b) (:list a) (:list b)))) f
        (hp-cons h t))
       (hp-cons (hap* f h)
        (hap* (map (typ (:arrow* (:arrow* a b) (:list a) (:list b)))) f t))))))

#|
Goal: SKOLEM_THM

   ∀P. (∀x. ∃y. P x y) ⇔ ∃f. ∀x. P x (f x)

Auxiliary definitions:

   ⊢ ∀P x y. Lam_0 P x y ⇔ P x y
⊢ ∀P x. Lam_1 P x ⇔ $? (Lam_0 P x)
⊢ ∀P f x. Lam_2 P f x ⇔ P x (f x)
⊢ ∀P f. Lam_3 P f ⇔ $! (Lam_2 P f)

Lifted goal:

   ∀P. $! (Lam_1 P) ⇔ $? (Lam_3 P)
|#

(defhol
   :fns ((lam_0 (:arrow* (:arrow* a b :bool) a b :bool)))
   :defs ((:forall ((p (:arrow* a b :bool)) (x a) (y b))
      (equal
       (hap* (lam_0 (typ (:arrow* (:arrow* a b :bool) a b :bool))) p x y)
       (hap* p x y)))))

(defhol
   :fns ((lam_1 (:arrow* (:arrow* a b :bool) a :bool)))
   :defs ((:forall ((p (:arrow* a b :bool)) (x a))
      (equal (hap* (lam_1 (typ (:arrow* (:arrow* a b :bool) a :bool))) p x)
       (hp-exists
        (hap* (lam_0 (typ (:arrow* (:arrow* a b :bool) a b :bool))) p x))))))

(defhol
   :fns ((lam_2 (:arrow* (:arrow* a b :bool) (:arrow* a b) a :bool)))
   :defs ((:forall ((p (:arrow* a b :bool)) (f (:arrow* a b)) (x a))
      (equal
       (hap* (lam_2 (typ (:arrow* (:arrow* a b :bool) (:arrow* a b) a :bool)))
        p f x) (hap* p x (hap* f x))))))

(defhol
   :fns ((lam_3 (:arrow* (:arrow* a b :bool) (:arrow* a b) :bool)))
   :defs ((:forall ((p (:arrow* a b :bool)) (f (:arrow* a b)))
      (equal
       (hap* (lam_3 (typ (:arrow* (:arrow* a b :bool) (:arrow* a b) :bool))) p
        f)
       (hp-forall
        (hap*
         (lam_2 (typ (:arrow* (:arrow* a b :bool) (:arrow* a b) a :bool))) p
         f))))))

(defhol
   :name skolem_thm
   :goal (:forall ((p (:arrow* a b :bool)))
     (hp=
      (hp-forall (hap* (lam_1 (typ (:arrow* (:arrow* a b :bool) a :bool))) p))
      (hp-exists
       (hap* (lam_3 (typ (:arrow* (:arrow* a b :bool) (:arrow* a b) :bool)))
        p)))))

#|
Theorem: num_ind

   ⊢ ∀P. P 0 ∧ (∀n. P n ⇒ P (SUC n)) ⇒ ∀n. P n

Auxiliary definitions:

   ⊢ ∀P n. Lam_4 P n ⇔ P n ⇒ P (SUC n)
   ⊢ ∀P n. Lam_5 P n ⇔ P n

Lifted theorem:

   ⊢ ∀P. P 0 ∧ $! (Lam_4 P) ⇒ $! (Lam_5 P)
|#

(defhol
   :fns ((lam_4 (:arrow* (:arrow* :num :bool) :num :bool)))
   :defs ((:forall ((p (:arrow* :num :bool)) (n :num))
      (equal
       (hap* (lam_4 (typ (:arrow* (:arrow* :num :bool) :num :bool))) p n)
       (hp-implies (hap* p n)
        (hap* p (hap* (suc (typ (:arrow* :num :num))) n)))))))

(defhol
   :fns ((lam_5 (:arrow* (:arrow* :num :bool) :num :bool)))
   :defs ((:forall ((p (:arrow* :num :bool)) (n :num))
      (equal
       (hap* (lam_5 (typ (:arrow* (:arrow* :num :bool) :num :bool))) p n)
       (hap* p n)))))

(defhol
   :name num_ind
   :thm (:forall ((p (:arrow* :num :bool)))
     (hp-implies
      (hp-and (hap* p (hp-num 0))
       (hp-forall
        (hap* (lam_4 (typ (:arrow* (:arrow* :num :bool) :num :bool))) p)))
      (hp-forall
       (hap* (lam_5 (typ (:arrow* (:arrow* :num :bool) :num :bool))) p)))))

#|
Theorem: list_ind

   ⊢ ∀P. P [] ∧ (∀t. P t ⇒ ∀h. P (h::t)) ⇒ ∀l. P l

Auxiliary definitions:

   ⊢ ∀P t h. Lam_6 P t h ⇔ P (h::t)
   ⊢ ∀P t. Lam_7 P t ⇔ P t ⇒ $! (Lam_6 P t)
   ⊢ ∀P l. Lam_8 P l ⇔ P l

Lifted theorem:

   ⊢ ∀P. P [] ∧ $! (Lam_7 P) ⇒ $! (Lam_8 P)
|#

(defhol
   :fns ((lam_6 (:arrow* (:arrow* (:list a) :bool) (:list a) a :bool)))
   :defs ((:forall ((p (:arrow* (:list a) :bool)) (t (:list a)) (h a))
      (equal
       (hap*
        (lam_6 (typ (:arrow* (:arrow* (:list a) :bool) (:list a) a :bool))) p
        t h) (hap* p (hp-cons h t))))))

(defhol
   :fns ((lam_7 (:arrow* (:arrow* (:list a) :bool) (:list a) :bool)))
   :defs ((:forall ((p (:arrow* (:list a) :bool)) (t (:list a)))
      (equal
       (hap* (lam_7 (typ (:arrow* (:arrow* (:list a) :bool) (:list a) :bool)))
        p t)
       (hp-implies (hap* p t)
        (hp-forall
         (hap*
          (lam_6 (typ (:arrow* (:arrow* (:list a) :bool) (:list a) a :bool)))
          p t)))))))

(defhol
   :fns ((lam_8 (:arrow* (:arrow* (:list a) :bool) (:list a) :bool)))
   :defs ((:forall ((p (:arrow* (:list a) :bool)) (l (:list a)))
      (equal
       (hap* (lam_8 (typ (:arrow* (:arrow* (:list a) :bool) (:list a) :bool)))
        p l) (hap* p l)))))

(defhol
   :name list_ind
   :thm (:forall ((p (:arrow* (:list a) :bool)))
     (hp-implies
      (hp-and (hap* p (hp-nil (typ a)))
       (hp-forall
        (hap*
         (lam_7 (typ (:arrow* (:arrow* (:list a) :bool) (:list a) :bool))) p)))
      (hp-forall
       (hap* (lam_8 (typ (:arrow* (:arrow* (:list a) :bool) (:list a) :bool)))
        p)))))

#|
Original definition:

   ⊢ ∀R a b.
       R⁺ a b ⇔
       ∀P. (∀x y. R x y ⇒ P x y) ∧ (∀x y z. P x y ∧ P y z ⇒ P x z) ⇒ P a b

Auxiliary definitions:

   ⊢ ∀R x P y. Lam_9 R x P y ⇔ R x y ⇒ P x y
   ⊢ ∀R P x. Lam_10 R P x ⇔ $! (Lam_9 R x P)
   ⊢ ∀P x y z. Lam_11 P x y z ⇔ P x y ∧ P y z ⇒ P x z
   ⊢ ∀P x y. Lam_12 P x y ⇔ $! (Lam_11 P x y)
   ⊢ ∀P x. Lam_13 P x ⇔ $! (Lam_12 P x)
   ⊢ ∀R a b P. Lam_14 R a b P ⇔ $! (Lam_10 R P) ∧ $! (Lam_13 P) ⇒ P a b

Lifted definition:

   ⊢ ∀R a b. R⁺ a b ⇔ $! (Lam_14 R a b)
|#

(defhol
   :fns ((lam_9 (:arrow* (:arrow* a a :bool) a (:arrow* a a :bool) a :bool)))
   :defs ((:forall
      ((r (:arrow* a a :bool)) (x a) (p (:arrow* a a :bool)) (y a))
      (equal
       (hap*
        (lam_9
         (typ (:arrow* (:arrow* a a :bool) a (:arrow* a a :bool) a :bool))) r
        x p y) (hp-implies (hap* r x y) (hap* p x y))))))

(defhol
   :fns ((lam_10 (:arrow* (:arrow* a a :bool) (:arrow* a a :bool) a :bool)))
   :defs ((:forall ((r (:arrow* a a :bool)) (p (:arrow* a a :bool)) (x a))
      (equal
       (hap*
        (lam_10
         (typ (:arrow* (:arrow* a a :bool) (:arrow* a a :bool) a :bool))) r p
        x)
       (hp-forall
        (hap*
         (lam_9
          (typ (:arrow* (:arrow* a a :bool) a (:arrow* a a :bool) a :bool))) r
         x p))))))

(defhol
   :fns ((lam_11 (:arrow* (:arrow* a a :bool) a a a :bool)))
   :defs ((:forall ((p (:arrow* a a :bool)) (x a) (y a) (z a))
      (equal
       (hap* (lam_11 (typ (:arrow* (:arrow* a a :bool) a a a :bool))) p x y z)
       (hp-implies (hp-and (hap* p x y) (hap* p y z)) (hap* p x z))))))

(defhol
   :fns ((lam_12 (:arrow* (:arrow* a a :bool) a a :bool)))
   :defs ((:forall ((p (:arrow* a a :bool)) (x a) (y a))
      (equal
       (hap* (lam_12 (typ (:arrow* (:arrow* a a :bool) a a :bool))) p x y)
       (hp-forall
        (hap* (lam_11 (typ (:arrow* (:arrow* a a :bool) a a a :bool))) p x y))))))

(defhol
   :fns ((lam_13 (:arrow* (:arrow* a a :bool) a :bool)))
   :defs ((:forall ((p (:arrow* a a :bool)) (x a))
      (equal (hap* (lam_13 (typ (:arrow* (:arrow* a a :bool) a :bool))) p x)
       (hp-forall
        (hap* (lam_12 (typ (:arrow* (:arrow* a a :bool) a a :bool))) p x))))))

(defhol
   :fns ((lam_14 (:arrow* (:arrow* a a :bool) a a (:arrow* a a :bool) :bool)))
   :defs ((:forall
      ((r (:arrow* a a :bool)) (a a) (b a) (p (:arrow* a a :bool)))
      (equal
       (hap*
        (lam_14
         (typ (:arrow* (:arrow* a a :bool) a a (:arrow* a a :bool) :bool))) r
        a b p)
       (hp-implies
        (hp-and
         (hp-forall
          (hap*
           (lam_10
            (typ (:arrow* (:arrow* a a :bool) (:arrow* a a :bool) a :bool))) r
           p))
         (hp-forall
          (hap* (lam_13 (typ (:arrow* (:arrow* a a :bool) a :bool))) p)))
        (hap* p a b))))))

(defhol
   :fns ((tc (:arrow* (:arrow* a a :bool) a a :bool)))
   :defs ((:forall ((r (:arrow* a a :bool)) (a a) (b a))
      (equal (hap* (tc (typ (:arrow* (:arrow* a a :bool) a a :bool))) r a b)
       (hp-forall
        (hap*
         (lam_14
          (typ (:arrow* (:arrow* a a :bool) a a (:arrow* a a :bool) :bool))) r
         a b))))))

#|
Theorem: rtc_ind

   ⊢ ∀R P.
       (∀x. P x x) ∧ (∀x y z. R x y ∧ P y z ⇒ P x z) ⇒
       ∀a0 a1. R꙳ a0 a1 ⇒ P a0 a1

Auxiliary definitions:

   ⊢ ∀P x. Lam_15 P x ⇔ P x x
   ⊢ ∀R x y P z. Lam_16 R x y P z ⇔ R x y ∧ P y z ⇒ P x z
   ⊢ ∀R x P y. Lam_17 R x P y ⇔ $! (Lam_16 R x y P)
   ⊢ ∀R P x. Lam_18 R P x ⇔ $! (Lam_17 R x P)
   ⊢ ∀R a0 P a1. Lam_19 R a0 P a1 ⇔ R꙳ a0 a1 ⇒ P a0 a1
   ⊢ ∀R P a0. Lam_20 R P a0 ⇔ $! (Lam_19 R a0 P)

Lifted theorem:

   ⊢ ∀R P. $! (Lam_15 P) ∧ $! (Lam_18 R P) ⇒ $! (Lam_20 R P)
|#

(defhol
   :fns ((lam_15 (:arrow* (:arrow* a a :bool) a :bool)))
   :defs ((:forall ((p (:arrow* a a :bool)) (x a))
      (equal (hap* (lam_15 (typ (:arrow* (:arrow* a a :bool) a :bool))) p x)
       (hap* p x x)))))

(defhol
   :fns ((lam_16
      (:arrow* (:arrow* a a :bool) a a (:arrow* a a :bool) a :bool)))
   :defs ((:forall
      ((r (:arrow* a a :bool)) (x a) (y a) (p (:arrow* a a :bool)) (z a))
      (equal
       (hap*
        (lam_16
         (typ (:arrow* (:arrow* a a :bool) a a (:arrow* a a :bool) a :bool)))
        r x y p z)
       (hp-implies (hp-and (hap* r x y) (hap* p y z)) (hap* p x z))))))

(defhol
   :fns ((lam_17 (:arrow* (:arrow* a a :bool) a (:arrow* a a :bool) a :bool)))
   :defs ((:forall
      ((r (:arrow* a a :bool)) (x a) (p (:arrow* a a :bool)) (y a))
      (equal
       (hap*
        (lam_17
         (typ (:arrow* (:arrow* a a :bool) a (:arrow* a a :bool) a :bool))) r
        x p y)
       (hp-forall
        (hap*
         (lam_16
          (typ (:arrow* (:arrow* a a :bool) a a (:arrow* a a :bool) a :bool)))
         r x y p))))))

(defhol
   :fns ((lam_18 (:arrow* (:arrow* a a :bool) (:arrow* a a :bool) a :bool)))
   :defs ((:forall ((r (:arrow* a a :bool)) (p (:arrow* a a :bool)) (x a))
      (equal
       (hap*
        (lam_18
         (typ (:arrow* (:arrow* a a :bool) (:arrow* a a :bool) a :bool))) r p
        x)
       (hp-forall
        (hap*
         (lam_17
          (typ (:arrow* (:arrow* a a :bool) a (:arrow* a a :bool) a :bool))) r
         x p))))))

(defhol
   :fns ((lam_19 (:arrow* (:arrow* a a :bool) a (:arrow* a a :bool) a :bool)))
   :defs ((:forall
      ((r (:arrow* a a :bool)) (a0 a) (p (:arrow* a a :bool)) (a1 a))
      (equal
       (hap*
        (lam_19
         (typ (:arrow* (:arrow* a a :bool) a (:arrow* a a :bool) a :bool))) r
        a0 p a1)
       (hp-implies
        (hap* (rtc (typ (:arrow* (:arrow* a a :bool) a a :bool))) r a0 a1)
        (hap* p a0 a1))))))

(defhol
   :fns ((lam_20 (:arrow* (:arrow* a a :bool) (:arrow* a a :bool) a :bool)))
   :defs ((:forall ((r (:arrow* a a :bool)) (p (:arrow* a a :bool)) (a0 a))
      (equal
       (hap*
        (lam_20
         (typ (:arrow* (:arrow* a a :bool) (:arrow* a a :bool) a :bool))) r p
        a0)
       (hp-forall
        (hap*
         (lam_19
          (typ (:arrow* (:arrow* a a :bool) a (:arrow* a a :bool) a :bool))) r
         a0 p))))))

(defhol
   :name rtc_ind
   :thm (:forall ((r (:arrow* a a :bool)) (p (:arrow* a a :bool)))
     (hp-implies
      (hp-and
       (hp-forall
        (hap* (lam_15 (typ (:arrow* (:arrow* a a :bool) a :bool))) p))
       (hp-forall
        (hap*
         (lam_18
          (typ (:arrow* (:arrow* a a :bool) (:arrow* a a :bool) a :bool))) r
         p)))
      (hp-forall
       (hap*
        (lam_20
         (typ (:arrow* (:arrow* a a :bool) (:arrow* a a :bool) a :bool))) r p)))))

#|
Theorem: pforall_thm

   ⊢ ∀P. (∀x y. P x y) ⇔ ∀(x,y). P x y

Auxiliary definitions:

   ⊢ ∀P x y. Lam_21 P x y ⇔ P x y
   ⊢ ∀P x. Lam_22 P x ⇔ $! (Lam_21 P x)
   ⊢ ∀P x y. Lam_23 P x y ⇔ P x y

Lifted theorem:

   ⊢ ∀P. $! (Lam_22 P) ⇔ $! (UNCURRY (Lam_23 P))
|#

(defhol
   :fns ((lam_21 (:arrow* (:arrow* a b :bool) a b :bool)))
   :defs ((:forall ((p (:arrow* a b :bool)) (x a) (y b))
      (equal
       (hap* (lam_21 (typ (:arrow* (:arrow* a b :bool) a b :bool))) p x y)
       (hap* p x y)))))

(defhol
   :fns ((lam_22 (:arrow* (:arrow* a b :bool) a :bool)))
   :defs ((:forall ((p (:arrow* a b :bool)) (x a))
      (equal (hap* (lam_22 (typ (:arrow* (:arrow* a b :bool) a :bool))) p x)
       (hp-forall
        (hap* (lam_21 (typ (:arrow* (:arrow* a b :bool) a b :bool))) p x))))))

(defhol
   :fns ((lam_23 (:arrow* (:arrow* a b :bool) a b :bool)))
   :defs ((:forall ((p (:arrow* a b :bool)) (x a) (y b))
      (equal
       (hap* (lam_23 (typ (:arrow* (:arrow* a b :bool) a b :bool))) p x y)
       (hap* p x y)))))

(defhol
   :name pforall_thm
   :thm (:forall ((p (:arrow* a b :bool)))
     (hp=
      (hp-forall
       (hap* (lam_22 (typ (:arrow* (:arrow* a b :bool) a :bool))) p))
      (hp-forall
       (hap* (uncurry (typ (:arrow* (:arrow* a b :bool) (:hash a b) :bool)))
        (hap* (lam_23 (typ (:arrow* (:arrow* a b :bool) a b :bool))) p))))))

#|
Theorem: pair_cases

   ⊢ ∀x. ∃q r. x = (q,r)

Auxiliary definitions:

   ⊢ ∀x q r. Lam_24 x q r ⇔ x = (q,r)
   ⊢ ∀x q. Lam_25 x q ⇔ $? (Lam_24 x q)

Lifted theorem:

   ⊢ ∀x. $? (Lam_25 x)
|#

(defhol
   :fns ((lam_24 (:arrow* (:hash a b) a b :bool)))
   :defs ((:forall ((x (:hash a b)) (q a) (r b))
      (equal (hap* (lam_24 (typ (:arrow* (:hash a b) a b :bool))) x q r)
       (hp= x (hp-comma q r))))))

(defhol
   :fns ((lam_25 (:arrow* (:hash a b) a :bool)))
   :defs ((:forall ((x (:hash a b)) (q a))
      (equal (hap* (lam_25 (typ (:arrow* (:hash a b) a :bool))) x q)
       (hp-exists (hap* (lam_24 (typ (:arrow* (:hash a b) a b :bool))) x q))))))

(defhol
   :name pair_cases
   :thm (:forall ((x (:hash a b)))
     (hp-exists (hap* (lam_25 (typ (:arrow* (:hash a b) a :bool))) x))))

#|
Theorem: pair_case_eq

   ⊢ pair_CASE p f = v ⇔ ∃x y. p = (x,y) ∧ f x y = v

Auxiliary definitions:

   ⊢ ∀p x f v y. Lam_26 p x f v y ⇔ p = (x,y) ∧ f x y = v
   ⊢ ∀p f v x. Lam_27 p f v x ⇔ $? (Lam_26 p x f v)

Lifted theorem:

   ⊢ pair_CASE p f = v ⇔ $? (Lam_27 p f v)
|#

(defhol
   :fns ((lam_26 (:arrow* (:hash b c) b (:arrow* b c a) a c :bool)))
   :defs ((:forall ((p (:hash b c)) (x b) (f (:arrow* b c a)) (v a) (y c))
      (equal
       (hap* (lam_26 (typ (:arrow* (:hash b c) b (:arrow* b c a) a c :bool)))
        p x f v y) (hp-and (hp= p (hp-comma x y)) (hp= (hap* f x y) v))))))

(defhol
   :fns ((lam_27 (:arrow* (:hash b c) (:arrow* b c a) a b :bool)))
   :defs ((:forall ((p (:hash b c)) (f (:arrow* b c a)) (v a) (x b))
      (equal
       (hap* (lam_27 (typ (:arrow* (:hash b c) (:arrow* b c a) a b :bool))) p
        f v x)
       (hp-exists
        (hap* (lam_26 (typ (:arrow* (:hash b c) b (:arrow* b c a) a c :bool)))
         p x f v))))))

(defhol
   :name pair_case_eq
   :thm (hp=
     (hp= (hap* (pair_case (typ (:arrow* (:hash b c) (:arrow* b c a) a))) p f)
      v)
     (hp-exists
      (hap* (lam_27 (typ (:arrow* (:hash b c) (:arrow* b c a) a b :bool))) p f
       v))))

