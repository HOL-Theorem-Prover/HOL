all: $(DEFAULT_TARGETS) TraceRecord.uo ReplayTrace.uo MergeTrace.uo
.PHONY: all

ifdef POLY
MINSTATE = $(dprot $(HOLDIR)/bin/hol.state.min)

$(MINSTATE): ReplayTrace.uo MergeTrace.uo $(dprot $(HOLDIR)/bin/hol)
	$(protect $(HOLDIR)/bin/hol) buildheap --poly -o $@ \
	  $(protect $(SIGOBJ)/HolKernel) \
	  ReplayTrace MergeTrace

PROOFTRACE = $(dprot $(HOLDIR)/bin/prooftrace)
EXTRA_CLEANS += $(PROOFTRACE)

$(PROOFTRACE): $(MINSTATE) prooftrace_main.uo \
               $(dprot $(HOLDIR)/bin/hol)
	$(protect $(HOLDIR)/bin/hol) buildheap --exe=main \
	  -b $(MINSTATE) \
	  -o $(protect $(HOLDIR)/bin/prooftrace) \
	  prooftrace_main

all: $(MINSTATE) $(PROOFTRACE)
endif
