CLINE_OPTIONS = --no_overlay
ifdef POLY
CLINE_OPTIONS += --poly_not_hol
endif

all: $(DEFAULT_TARGETS)

theorystats.ui: theorystats.sig $(dprot $(SIGOBJ)/Graph.ui) $(dprot $(SIGOBJ)/Table.ui)
	$(HOLMOSMLC) -c Table.ui Graph.ui $<

theorystats.uo: theorystats.sml theorystats.ui $(dprot $(SIGOBJ)/Graph.ui) $(dprot $(SIGOBJ)/SHA1.uo)
	$(HOLMOSMLC) -c Graph.ui $<

HAVE_MLTON = $(if $(NO_MLTON),,$(which mlton))
ifneq ($(HAVE_MLTON),)
all: dat-printer theorytool

GETOPT = ../../../tools/util/GetOpt.sig ../../../tools/util/GetOpt.sml

dat-printer: dat-printer.mlb RawTermPP.sml RawTheoryReader.sig RawTheoryReader.sml mlton-datprinter.ML DatPrinterTool.ML $(GETOPT)
	mlton -default-type intinf $<

theorytool: theorytool.mlb theorystats.sml theorytool.ML mlton-theorytool.ML $(GETOPT)
	mlton -default-type intinf $<

else ifdef POLY
all: dat-printer theorytool

dat-printer: mkdatprinter.ML DatPrinterTool.ML RawTermPP.uo
	$(POLYC) -o $@ $<

theorytool: mktool.ML theorytool.ML theorystats.uo
	$(POLYC) -o $@ $<

endif

EXTRA_CLEANS = dat-printer theorytool
