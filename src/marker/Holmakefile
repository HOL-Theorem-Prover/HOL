all: $(DEFAULT_TARGETS) selftest.exe
.PHONY: all

ifeq ($(KERNELID),otknl)
all: $(patsubst %Script.sml,%.ot.art,$(wildcard *Script.sml))

endif

selftest.exe: selftest.uo
	$(HOLMOSMLC) -o $@ $<

ifdef HOLSELFTESTLEVEL

all: marker-selftest.log

marker-selftest.log: selftest.exe
	$(tee ./selftest.exe 2>&1,$@)
endif

EXTRA_CLEANS = selftest.exe marker-selftest.log
