INCLUDES = ../Tools

# Core LaTeX file stems that contribute to tutorial.pdf.  Front
# matter (title, preface) is still hand-coded in tutorial.tex;
# everything else is wired in through chapters-include.tex which
# gen_chap_lists generates from chapters.txt.  The bibliography is
# now produced from tutorial.bib via natbib (see tutorial.pdf
# recipe below), mirroring Manual/Description/.
TEX_CORES = tutorial title preface intro ml writinghol euclid \
            parity combin proof-tools more-examples

TEX_SOURCES = ../LaTeX/ack.tex ../LaTeX/commands.tex \
              chapters-include.tex book-title.tex tutorial.bib \
              $(patsubst %,%.tex,$(TEX_CORES))

PS_ROOT = ../Tools/polyscripter
PS_STUFF = $(PS_ROOT) ../Tools/umap
PS_NOUMAP = $(PS_ROOT) -md < $< > $@

# pandoc invocation for the .md -> .tex stage.  Same as the
# Description Holmakefile uses.
PANDOC_MD = pandoc --top-level-division=chapter --table-caption-position=below --lua-filter=../pdf-macros.lua -t latex $< > $@

.PHONY: all mdbook mdbook-serve

all: tutorial.pdf

# All .smd files in the directory; pick them up automatically so
# adding a new .smd doesn't require a Holmakefile edit just to wire
# its dependencies into the mdbook prereq chain.
SMDS = $(wildcard *.smd)
SMD_MDS = $(patsubst %.smd,%.md,$(SMDS))

# SVG renderings of the chapter figures, for the mdbook side.  The
# matching \input{} of each figure's standalone TikZ source lives
# inside the {=latex} blocks of the chapter .smd files and is
# picked up by the PDF pipeline as usual.  (Holmake pattern rules
# don't support directory-prefixed targets, so each figure gets an
# explicit rule.)
SVG_FIGS = figs/combin-confluence.svg \
           figs/combin-confluence-complete.svg

figs/combin-confluence.svg: figs/combin-confluence.tex
	cd figs && pdflatex -interaction=batchmode combin-confluence.tex
	pdftocairo -svg figs/combin-confluence.pdf $@
	rm -f figs/combin-confluence.aux figs/combin-confluence.log \
	      figs/combin-confluence.pdf

figs/combin-confluence-complete.svg: figs/combin-confluence-complete.tex
	cd figs && pdflatex -interaction=batchmode combin-confluence-complete.tex
	pdftocairo -svg figs/combin-confluence-complete.pdf $@
	rm -f figs/combin-confluence-complete.aux \
	      figs/combin-confluence-complete.log \
	      figs/combin-confluence-complete.pdf

# Build the mdbook output for the chapters listed in SUMMARY.md;
# afterwards, scan the rendered HTML for raw-LaTeX leak patterns and
# cross-reference number drift.
mdbook: ../Tools/smdpp SUMMARY.md ../Tools/mdbook-check.sh $(SMD_MDS) \
        $(SVG_FIGS)
	mdbook build
	../Tools/mdbook-check.sh ../book/Tutorial
	../Tools/smdpp check-refs ../book/Tutorial
	../Tools/smdpp check-links ../book/Tutorial

# SUMMARY.md and chapters-include.tex are generated from
# chapters.txt by Manual/Tools/gen_chap_lists.  The mdbook H1 at
# the top of the sidebar uses the book title from book.toml so
# there's a single canonical source for the manual's name (also
# read by book-title.tex for the PDF; see below).
SUMMARY.md: ../Tools/gen_chap_lists chapters.txt book.toml $(SMDS)
	../Tools/gen_chap_lists summary \
	   "$$(awk -F\" '/^title/ {print $$2; exit}' book.toml)" > $@

chapters-include.tex: ../Tools/gen_chap_lists chapters.txt
	../Tools/gen_chap_lists latex-include > $@

# Generate a one-line LaTeX macro file whose body is the book
# title from book.toml; title.tex and tutorial.tex (via
# \HOLbookTitle) consume it.  Keeps the PDF cover and the
# hyperref pdftitle in sync with the mdbook title automatically.
book-title.tex: book.toml
	printf '\\providecommand{\\HOLbookTitle}{%s}\n' \
	   "$$(awk -F\" '/^title/ {print $$2; exit}' book.toml)" > $@

# Convenience: serve the book locally at http://127.0.0.1:3001/.
# Port 3001 (instead of Description's 3000) so the two manuals can
# be served side by side.  Detaches into the background; pass LOG=1
# to capture the server's stdout/stderr to mdbook-serve.log here,
# or LOG=<path> for a custom location.
mdbook-serve: ../Tools/smdpp
	@msg() { { echo "$$1" >/dev/tty; } 2>/dev/null || echo "$$1" >&2; }; \
	 if lsof -ti :3001 >/dev/null 2>&1; then \
	   msg "Port 3001 already in use; stop the existing server first:"; \
	   msg "  pkill -f 'mdbook serve'  (or: lsof -ti :3001 | xargs kill)"; \
	   exit 1; \
	 fi; \
	 logfile="$(LOG)"; \
	 [ "$$logfile" = 1 ] && logfile=mdbook-serve.log; \
	 [ -z "$$logfile" ] && logfile=/dev/null; \
	 (mdbook serve --hostname 127.0.0.1 --port 3001 \
	    >"$$logfile" 2>&1 &); \
	 msg "mdbook serving at http://127.0.0.1:3001/"; \
	 [ "$$logfile" != /dev/null ] && msg "log: $$(pwd)/$$logfile"; \
	 msg "stop: pkill -f 'mdbook serve'"

# latexmk-side flags mirror Manual/Description/Holmakefile:
#   -bibtex: this latexmk (4.79) doesn't auto-invoke bibtex from
#     the .aux's \bibdata line on its own; the explicit flag forces
#     it through.
#   -f: pdflatex returns exit 1 on natbib warnings about undefined
#     citations in early passes, which without -f makes latexmk
#     abort the loop; we treat the actual PDF's existence as the
#     success signal.
# Trailing pdflatex pass: latexmk's convergence loop sometimes
# stops one pass too early when the second bibtex run produces
# the same .bbl as the first -- but pdflatex still needs another
# pass to incorporate the \bibcite entries it has only just
# written to its own .aux for early-document citations.
tutorial.pdf: $(TEX_SOURCES)
	rm -f $@; \
	latexmk -pdf -bibtex -f -interaction=nonstopmode tutorial; \
	pdflatex -interaction=nonstopmode tutorial > /dev/null; \
	test -s $@

# Pattern rules for the per-chapter .smd -> .md -> .tex pipeline.
# Hand-rolled .tex front matter (tutorial.tex, title.tex,
# preface.tex, references.tex) is safe: Holmake skips pattern rules
# whose prereqs don't exist (see Manual/Description/misc.smd's
# pattern-rule applicability note).
%.md: %.smd
	$(PS_NOUMAP)

%.tex: %.md ../pdf-macros.lua
	$(PANDOC_MD)

# $(PS_STUFF) lives in ../Tools/ and is only built on demand, so the
# pattern rule's applicability check (local rules + files only)
# would reject %.md before ../Tools/polyscripter exists.  Declare it
# as a recipe-less extra prereq on every .md, leaving the pattern
# recipe to apply.
$(SMD_MDS): $(PS_STUFF)

# Per-chapter extra prerequisites: side files polyscripter reads
# from a chapter's .smd via `##use`.  Recipe-less rules slot in on
# top of the pattern rule above (see "additional prerequisites"
# under pattern rules in Manual/Description/misc.smd).
euclid.md: euclid-extras.ML
proof-tools.md: ../../examples/dpll.sml

EXTRA_CLEANS = $(SMD_MDS) $(patsubst %.smd,%.tex,$(SMDS)) \
               tutorial.pdf SUMMARY.md chapters-include.tex \
               book-title.tex \
               $(patsubst %,%.aux,$(TEX_CORES)) \
               tutorial.log tutorial.out tutorial.toc \
               tutorial.fls tutorial.idx tutorial.ilg tutorial.ind \
               tutorial.blg tutorial.bbl tutorial.fdb_latexmk \
               mdbook-serve.log \
               $(SVG_FIGS) \
               $(patsubst %.svg,%.pdf,$(SVG_FIGS)) \
               $(patsubst %.svg,%.aux,$(SVG_FIGS)) \
               $(patsubst %.svg,%.log,$(SVG_FIGS)) \
               ../book/Tutorial/
