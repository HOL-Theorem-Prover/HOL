# =====================================================================
# Makefile for the HOL manual
# =====================================================================

INCLUDES = Description Logic Tutorial Reference Interaction-emacs Quick Cheatsheet Tools

all: description tutorial logic reference interaction quick cheatsheet
	@echo "=======> MANUAL made"
.PHONY: all

description: Description/description.pdf
logic: Logic/logic.pdf
tutorial: Tutorial/tutorial.pdf
reference: Reference/reference.pdf
interaction: Interaction-emacs/interaction-emacs.pdf
quick: Quick/quick.pdf
cheatsheet: Cheatsheet/cheatsheet.html

# Unified mdbook site -- one landing page at book/index.html with
# per-manual subdirectories underneath.  Each per-manual mdbook
# build is invoked recursively via its own Holmakefile.
.PHONY: mdbook description-mdbook tutorial-mdbook reference-mdbook \
        interaction-emacs-mdbook mdbook-serve

mdbook: description-mdbook tutorial-mdbook reference-mdbook \
        interaction-emacs-mdbook book/index.html

description-mdbook:
	cd Description && $(protect $(HOLDIR)/bin/Holmake) mdbook

tutorial-mdbook:
	cd Tutorial && $(protect $(HOLDIR)/bin/Holmake) mdbook

reference-mdbook:
	cd Reference && $(protect $(HOLDIR)/bin/Holmake) mdbook

interaction-emacs-mdbook:
	cd Interaction-emacs && $(protect $(HOLDIR)/bin/Holmake) mdbook

# Static landing page produced by Manual/Tools/gen_lander.  Cards
# for each manual whose book.toml is passed on the command line.
book/index.html: Tools/gen_lander Description/book.toml Tutorial/book.toml \
                 Reference/book.toml Interaction-emacs/book.toml
	mkdir -p book
	./Tools/gen_lander Description/book.toml Tutorial/book.toml \
	                   Reference/book.toml \
	                   Interaction-emacs/book.toml > $@

# Serve the unified site for cross-manual review.  Detaches into
# the background like the per-manual mdbook-serve recipes; pass
# LOG=1 to capture output to mdbook-serve.log (or LOG=<path> for
# a custom location).  Live-reload is not provided here -- use the
# per-manual mdbook-serve targets (port 3000 / 3001) when editing
# a single manual.
mdbook-serve: mdbook
	@msg() { { echo "$$1" >/dev/tty; } 2>/dev/null || echo "$$1" >&2; }; \
	 if lsof -ti :3002 >/dev/null 2>&1; then \
	   msg "Port 3002 already in use; stop the existing server first:"; \
	   msg "  pkill -f 'http.server 3002'  (or: lsof -ti :3002 | xargs kill)"; \
	   exit 1; \
	 fi; \
	 logfile="$(LOG)"; \
	 [ "$$logfile" = 1 ] && logfile=mdbook-serve.log; \
	 [ -z "$$logfile" ] && logfile=/dev/null; \
	 (cd book && python3 -m http.server 3002 --bind 0.0.0.0 \
	    >"$$logfile" 2>&1 &); \
	 msg "Unified site serving at http://127.0.0.1:3002/"; \
	 [ "$$logfile" != /dev/null ] && msg "log: $$(pwd)/$$logfile"; \
	 msg "stop: pkill -f 'http.server 3002'"

EXTRA_CLEANS = book/index.html

