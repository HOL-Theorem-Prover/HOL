# =====================================================================
# Makefile for the HOL manual
# =====================================================================

INCLUDES = Description Logic Tutorial Reference Interaction-emacs Developers Quick Cheatsheet Tools

all: description tutorial logic reference interaction quick cheatsheet
	@echo "=======> MANUAL made"
.PHONY: all

description: Description/description.pdf
logic: Logic/logic.pdf
tutorial: Tutorial/tutorial.pdf
reference: Reference/reference.pdf
interaction: Interaction-emacs/interaction-emacs.pdf
quick: Quick/quick.pdf
cheatsheet: Cheatsheet/cheatsheet.html

# Unified mdbook site -- one landing page at book/index.html with
# per-manual subdirectories underneath.  Both the aggregator's
# MDBOOK_TARGETS / BOOK_TOMLS and each per-manual Holmakefile's
# SIBLING_LABELS list are derived from the MANUALS list defined
# in mdbook.mk, so adding a new manual is a single-line edit there.
include mdbook.mk
MDBOOK_TARGETS = $(patsubst %,%/mdbook,$(MANUALS))
BOOK_TOMLS = $(patsubst %,%/book.toml,$(MANUALS))

.PHONY: mdbook

# To preview the built site locally (static serve, or with live-reload
# on source edits), use Manual/Tools/mdbook-preview.py from this dir:
#     ./Tools/mdbook-preview.py [--manual NAME] [--live]
# The script runs `Holmake mdbook` first so the served content matches
# a release build.
mdbook: $(MDBOOK_TARGETS) book/index.html book/.references.stamp

# Lander fragment generated by makebase (run during bin/build's
# build_help step).  We treat it as a precondition rather than a
# Holmakefile-managed target -- it's owned by the help/ subtree.
LANDER_FRAGMENT = $(HOLDIR)/help/HOL.LanderFragment.html

# Static landing page produced by Manual/Tools/gen_lander.  Cards
# for each manual whose book.toml is passed on the command line,
# followed by the reference fragment from $(LANDER_FRAGMENT).
book/index.html: Tools/gen_lander $(BOOK_TOMLS) $(LANDER_FRAGMENT)
	mkdir -p book
	./Tools/gen_lander --fragment $(LANDER_FRAGMENT) $(BOOK_TOMLS) > $@

# Stage the targets the Reference section links to.  stage_references
# copies the per-theory HTML pages (rewriting their parent-doc URLs so
# they resolve from book/theories/), copies the theory hierarchy SVG
# (rewriting node URLs to ../theories/), and symlinks htmlsigs/ whose
# contents are already self-consistent.  The stamp file gates re-run
# on the help DB regeneration; bin/build refreshes the source docs.
book/.references.stamp: $(LANDER_FRAGMENT) Tools/stage_references.py
	mkdir -p book
	python3 Tools/stage_references.py $(HOLDIR) book
	touch $@

EXTRA_CLEANS = book/index.html book/htmlsigs book/theory-graph \
               book/.references.stamp \
               build/Docfiles-processed/

