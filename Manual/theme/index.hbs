<!DOCTYPE HTML>
<html lang="{{ language }}" class="{{ default_theme }} sidebar-visible" dir="{{ text_direction }}">
    <head>
        <!-- Book generated using mdBook -->
        <meta charset="UTF-8">
        <title>{{ title }}</title>
        {{#if is_print }}
        <meta name="robots" content="noindex">
        {{/if}}
        {{#if base_url}}
        <base href="{{ base_url }}">
        {{/if}}


        <!-- Custom HTML head -->
        {{> head}}

        <!-- HOL_MANUALS: shared config consumed by Manual/theme/
             searcher.js (for cross-book search loading) and by the
             manual-switcher highlight JS further down the page.
             Keep this list in sync with the top-level Manual/Holmake-
             file's gen_lander invocation; if a fourth manual joins
             the site, add it here so its searchindex.js gets
             loaded alongside the others. -->
        <script>
            window.HOL_MANUALS = {
                books: ['Description', 'Tutorial', 'Reference']
            };
        </script>

        <meta name="description" content="{{ description }}">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="theme-color" content="#ffffff">

        {{#if favicon_svg}}
        <link rel="icon" href="{{ resource "favicon.svg" }}">
        {{/if}}
        {{#if favicon_png}}
        <link rel="shortcut icon" href="{{ resource "favicon.png" }}">
        {{/if}}
        <link rel="stylesheet" href="{{ resource "css/variables.css" }}">
        <link rel="stylesheet" href="{{ resource "css/general.css" }}">
        <link rel="stylesheet" href="{{ resource "css/chrome.css" }}">
        {{#if print_enable}}
        <link rel="stylesheet" href="{{ resource "css/print.css" }}" media="print">
        {{/if}}

        <!-- Fonts -->
        <link rel="stylesheet" href="{{ resource "FontAwesome/css/font-awesome.css" }}">
        {{#if copy_fonts}}
        <link rel="stylesheet" href="{{ resource "fonts/fonts.css" }}">
        {{/if}}

        <!-- Highlight.js Stylesheets -->
        <link rel="stylesheet" id="mdbook-highlight-css" href="{{ resource "highlight.css" }}">
        <link rel="stylesheet" id="mdbook-tomorrow-night-css" href="{{ resource "tomorrow-night.css" }}">
        <link rel="stylesheet" id="mdbook-ayu-highlight-css" href="{{ resource "ayu-highlight.css" }}">

        <!-- Custom theme stylesheets -->
        {{#each additional_css}}
        <link rel="stylesheet" href="{{ resource this }}">
        {{/each}}

        {{#if mathjax_support}}
        <!-- MathJax: enable $...$ for inline math (the default
             TeX-AMS-MML_HTMLorMML config only recognises \(...\) and
             $$...$$, but our sources use $...$). -->
        <script type="text/x-mathjax-config">
          MathJax.Hub.Config({
            tex2jax: {
              inlineMath: [['$','$'], ['\\(','\\)']],
              displayMath: [['$$','$$'], ['\\[','\\]']],
              processEscapes: true
            },
            TeX: {
              Macros: {
                // From LaTeX stmaryrd, which mdbook MathJax doesn't load.
                llbracket: ["{\\unicode{x27E6}}"],
                rrbracket: ["{\\unicode{x27E7}}"],
                llparenthesis: ["{\\unicode{x2987}}"],
                rrparenthesis: ["{\\unicode{x2988}}"],
                lbrbrak: ["{\\unicode{x2772}}"],
                rbrbrak: ["{\\unicode{x2773}}"],
                rightwhitearrow: ["{\\unicode{x21E8}}"],
                upand: ["{\\unicode{x214B}}"],
                // From bbm-defined \llbrace/\rrbrace in the source.
                llbrace: ["{\\unicode{x2983}}"],
                rrbrace: ["{\\unicode{x2984}}"],
                // Manual/LaTeX/commands.tex: \hilbert = \varepsilon.
                hilbert: ["\\varepsilon"],
                // Chapter-local LaTeX macros from Description's
                // theories.smd.  The PDF definitions live in the
                // {=latex} block at the top of that file; these are
                // the MathJax mirrors.
                konst: ["{\\mathsf{#1}}", 1],
                nil: ["{\\mathbf{[}\\;\\mathbf{]}}"],
                cons: ["{#1}\\mathbf{:}\\mathbf{:}{#2}", 2],
                subr: ["_{\\mathsf{r}}"],
                // Local macros for the bit-vectors subsection.
                fcp: ["#1[#2]", 2],
                worda: ["\\mathit{bool}[\\alpha]"],
                wordb: ["\\mathit{bool}[\\beta]"],
                wordc: ["\\mathit{bool}[\\gamma]"],
                // Chapter-local macros from Description's libraries.smd.
                term: ["\\mathit{term}"],
                type: ["\\mathit{type}"],
                // From commands.tex: \holtxt renders HOL syntax in
                // typewriter; \ml does the same outside math mode.
                holtxt: ["{\\mathtt{#1}}", 1],
                // Chapter-local LaTeX macros from Tutorial's combin.smd.
                // The PDF definitions live in the {=latex} block at the
                // top of that file; these are the MathJax mirrors.  \con
                // comes from Manual/LaTeX/commands.tex (\con{X} = \sf X).
                con: ["{\\mathsf{#1}}", 1],
                KC: ["{\\mathsf{K}}"],
                SC: ["{\\mathsf{S}}"],
                mathpredn: ["\\mathbin{-\\!\\!\\!\\mid\\mid\\!\\rightarrow}"],
                // \infer from proof.sty (used in latex-munger.smd's
                // examples of the `rule` and `stackedrule` options).
                // The premises are passed in #2, ampersand-separated;
                // wrap them in a matrix so MathJax accepts the &s and
                // lays the premises side-by-side over the conclusion.
                infer: ["{\\dfrac{\\begin{matrix}#2\\end{matrix}}{#1}}", 2]
              }
            }
          });
        </script>
        <script async src="https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.1/MathJax.js?config=TeX-AMS-MML_HTMLorMML"></script>
        {{/if}}

        <!-- Provide site root and default themes to javascript -->
        <script>
            const path_to_root = "{{ path_to_root }}";
            const default_light_theme = "{{ default_theme }}";
            const default_dark_theme = "{{ preferred_dark_theme }}";
        {{#if search_js}}
            window.path_to_searchindex_js = "{{ resource "searchindex.js" }}";
        {{/if}}
        </script>
        <!-- Start loading toc.js asap -->
        <script src="{{ resource "toc.js" }}"></script>
        <!-- Rewrite the draft-chapter sub-entries from SUMMARY.md into
             clickable anchor links into the parent chapter.  mdbook's
             SUMMARY.md doesn't natively support `chapter.md#anchor`
             style sub-entries (it checks file existence including the
             #anchor part), so we use draft entries (`- [Title]()`) and
             post-process them here. -->
        <script>
        (function () {
          function slugify(text) {
            // Mirrors pulldown-cmark's heading-id rule: lowercase;
            // drop characters that aren't a Unicode letter / digit,
            // space, `-`, or `_`; then convert each remaining space
            // to `-` (without collapsing consecutive `-`s).
            // Collapsing here gives the wrong anchor for headings
            // whose source contained an em-dash flanked by spaces
            // (the em-dash is dropped, leaving two spaces -> two
            // `-`s).  \p{L}\p{N} (rather than [a-z0-9]) preserves
            // diacritics: "Radon-Nikodým" -> "radon-nikodým"
            // matches pulldown-cmark, while the ASCII-only form
            // strips the ý and produces a dead anchor.
            return text.toLowerCase()
                       .replace(/[^\p{L}\p{N} _-]+/gu, '')
                       .replace(/ /g, '-')
                       .replace(/^-+|-+$/g, '');
          }
          // Walk up from a draft <li> through enclosing ol.section /
          // li.chapter-item pairs until we reach an ancestor li whose
          // own wrapper span carries an <a href> -- that's the
          // chapter (mdbook 0.5.x puts the chapter's wrapper and its
          // sub-sections' ol.section as sibling children of the same
          // li.chapter-item).
          function findChapterHref(draftLi) {
            let li = draftLi.parentElement;        // ol.section
            while (li) {
              li = li.parentElement;               // li.chapter-item or ol.chapter
              if (!li || li.tagName !== 'LI') return null;
              const a = li.querySelector(
                ':scope > span.chapter-link-wrapper > a[href]');
              // Skip already-rewritten ancestor drafts (their hrefs
              // include `#anchor`); keep walking up until we hit the
              // chapter's base URL.
              if (a && !a.getAttribute('href').includes('#')) {
                return a.getAttribute('href');
              }
              li = li.parentElement;               // ol.section (next level up)
            }
            return null;
          }
          // Same-page anchor navigation doesn't trigger toc.js's
          // active-link / .expanded logic.  Mark every ancestor
          // li.chapter-item along the parent chain as `expanded` --
          // the same walk mdbook 0.5.x's toc.js does for the active
          // chapter on page load.
          function expandAncestors(node) {
            while (node) {
              if (node.tagName === 'LI'
                  && node.classList.contains('chapter-item')) {
                node.classList.add('expanded');
              }
              node = node.parentElement;
            }
          }
          // Drop the `expanded` class from every chapter-item in the
          // sidebar.  Used to clear stale state from previously-clicked
          // subsections before re-expanding the path to the new click
          // target, so the sidebar shows only one open branch at a
          // time (the path to the current section).
          function collapseAllExpanded() {
            document.querySelectorAll(
              '#mdbook-sidebar li.chapter-item.expanded'
            ).forEach(function (li) {
              li.classList.remove('expanded');
            });
          }
          function rewrite() {
            // mdbook 0.5.x renders a draft sub-entry as
            //   <li><span class="chapter-link-wrapper"><span>1.1. Title</span>
            //       [<a class="chapter-fold-toggle">]</span></li>
            // (the inner <span> is the title; clickable entries use
            // <a href> in its place).  Replace the inner <span> with
            // an <a> pointing at the chapter's matching heading
            // anchor.  Leaves the surrounding wrapper / fold-toggle
            // untouched.
            document.querySelectorAll(
              'ol.section > li > span.chapter-link-wrapper > span:first-child'
            ).forEach(function (titleSpan) {
              const wrapper = titleSpan.parentElement;
              if (wrapper.querySelector('a[href]')) return;
              const draftLi = wrapper.parentElement;
              const parentHref = findChapterHref(draftLi);
              if (!parentHref) return;
              // Strip the section-number prefix ("1.1.") to get the title.
              const full = titleSpan.textContent.trim();
              const m = full.match(/^[\d.]+\s*(.+)$/);
              const title = m ? m[1] : full;
              const anchor = slugify(title);
              const a = document.createElement('a');
              a.setAttribute('href', parentHref + '#' + anchor);
              a.setAttribute('target', '_parent');
              a.addEventListener('click', function () {
                collapseAllExpanded();
                expandAncestors(draftLi);
              });
              while (titleSpan.firstChild) a.appendChild(titleSpan.firstChild);
              titleSpan.parentNode.replaceChild(a, titleSpan);
            });
          }
          // If the URL already carries a #hash (either from a fresh
          // page load or from cross-chapter navigation), find the
          // matching sidebar entry and expand its ancestors so the
          // user lands with the section already revealed.
          function expandForCurrentHash() {
            const hash = window.location.hash.slice(1);
            if (!hash) return;
            const match = document.querySelector(
              'ol.section a[href$="#' + CSS.escape(hash) + '"]');
            if (match) expandAncestors(match.parentElement);
          }
          // Pull section numbers out of the sidebar and prepend them
          // to the matching body headings.  Keeps mdbook's numbered
          // sidebar consistent with what readers see at the top of
          // each section in the main column (and matches the PDF).
          //
          // Scoping the section-entry walk to the *active* chapter's
          // sub-list matters: chapters routinely share heading text
          // (e.g. multiple chapters have an "Exercises" section), and
          // a flat map keyed by slugify(heading) would let later
          // chapters' numbers overwrite earlier ones — so on chapter
          // N the body's "Exercises" heading would render with chapter
          // M's number (M > N).
          function numberBodyHeadings() {
            const numbersBySlug = new Map();
            // The chapter title's <h1> in the body matches the active
            // sidebar chapter link.
            const active = document.querySelector('a.active');
            if (active) {
              const txt = (active.textContent || '').trim();
              const m = txt.match(/^([\d.]+)\s*(.+)$/);
              if (m) {
                numbersBySlug.set(slugify(m[2]), m[1]);
              }
            }
            // mdbook 0.5.x puts the chapter's wrapper span and its
            // sub-section <ol class="section"> as sibling children of
            // the same <li class="chapter-item">.  Scope the
            // section-entry walk to *that* ol.section so we don't pick
            // up other chapters' numbers for headings that share text
            // with ours.
            let sectionsRoot = null;
            if (active) {
              const chapterLi = active.closest('li.chapter-item');
              if (chapterLi) {
                sectionsRoot = chapterLi.querySelector(':scope > ol.section');
              }
            }
            const scope = sectionsRoot || document;
            // Sidebar section entries' title sits inside
            // <span class="chapter-link-wrapper">, as either an <a>
            // (clickable or post-rewrite) or an inner <span>
            // (pre-rewrite draft); both work for textContent.
            scope.querySelectorAll(
              'ol.section li > span.chapter-link-wrapper > a,'
              + 'ol.section li > span.chapter-link-wrapper > span:first-child'
            ).forEach(function (el) {
              const txt = (el.textContent || '').trim();
              const m = txt.match(/^([\d.]+)\s*(.+)$/);
              if (!m) return;
              numbersBySlug.set(slugify(m[2]), m[1]);
            });
            document.querySelectorAll('main h1, main h2, main h3, main h4')
                    .forEach(function (h) {
              if (h.dataset.numbered === 'true' || !h.id) return;
              const num = numbersBySlug.get(h.id);
              if (!num) return;
              const span = document.createElement('span');
              span.className = 'section-num';
              span.textContent = num + ' ';
              h.insertBefore(span, h.firstChild);
              h.dataset.numbered = 'true';
            });
          }
          function applyAll() {
            rewrite();
            numberBodyHeadings();
            expandForCurrentHash();
          }
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', applyAll);
          } else {
            applyAll();
          }
          // Sidebar may also be loaded asynchronously by toc.js; poll
          // briefly to catch the late-rendered case.
          let tries = 0;
          const iv = setInterval(function () {
            if (document.querySelectorAll(
                  'ol.section li > span.chapter-link-wrapper > span'
                ).length > 0
                || document.querySelectorAll(
                     'main h1:not([data-numbered]), '
                   + 'main h2:not([data-numbered]), '
                   + 'main h3:not([data-numbered])').length > 0) {
              applyAll();
            }
            if (++tries > 20) clearInterval(iv);
          }, 50);
        })();
        </script>
    </head>
    <body>
    <div id="mdbook-help-container">
        <div id="mdbook-help-popup">
            <h2 class="mdbook-help-title">Keyboard shortcuts</h2>
            <div>
                <p>Press <kbd>←</kbd> or <kbd>→</kbd> to navigate between chapters</p>
                {{#if search_enabled}}
                <p>Press <kbd>S</kbd> or <kbd>/</kbd> to search in the book</p>
                {{/if}}
                <p>Press <kbd>?</kbd> to show this help</p>
                <p>Press <kbd>Esc</kbd> to hide this help</p>
            </div>
        </div>
    </div>
    <div id="mdbook-body-container">
        <!-- Work around some values being stored in localStorage wrapped in quotes -->
        <script>
            try {
                let theme = localStorage.getItem('mdbook-theme');
                let sidebar = localStorage.getItem('mdbook-sidebar');

                if (theme.startsWith('"') && theme.endsWith('"')) {
                    localStorage.setItem('mdbook-theme', theme.slice(1, theme.length - 1));
                }

                if (sidebar.startsWith('"') && sidebar.endsWith('"')) {
                    localStorage.setItem('mdbook-sidebar', sidebar.slice(1, sidebar.length - 1));
                }
            } catch (e) { }
        </script>

        <!-- Set the theme before any content is loaded, prevents flash -->
        <script>
            const default_theme = window.matchMedia("(prefers-color-scheme: dark)").matches ? default_dark_theme : default_light_theme;
            let theme;
            try { theme = localStorage.getItem('mdbook-theme'); } catch(e) { }
            if (theme === null || theme === undefined) { theme = default_theme; }
            const html = document.documentElement;
            html.classList.remove('{{ default_theme }}')
            html.classList.add(theme);
            html.classList.add("js");
        </script>

        <input type="checkbox" id="mdbook-sidebar-toggle-anchor" class="hidden">

        <!-- Hide / unhide sidebar before it is displayed -->
        <script>
            let sidebar = null;
            const sidebar_toggle = document.getElementById("mdbook-sidebar-toggle-anchor");
            if (document.body.clientWidth >= 1080) {
                try { sidebar = localStorage.getItem('mdbook-sidebar'); } catch(e) { }
                sidebar = sidebar || 'visible';
            } else {
                sidebar = 'hidden';
                sidebar_toggle.checked = false;
            }
            if (sidebar === 'visible') {
                sidebar_toggle.checked = true;
            } else {
                html.classList.remove('sidebar-visible');
            }
        </script>

        <nav id="mdbook-sidebar" class="sidebar" aria-label="Table of contents">
            <!-- populated by js -->
            <mdbook-sidebar-scrollbox class="sidebar-scrollbox"></mdbook-sidebar-scrollbox>
            <noscript>
                <iframe class="sidebar-iframe-outer" src="{{ path_to_root }}toc.html"></iframe>
            </noscript>
            <div id="mdbook-sidebar-resize-handle" class="sidebar-resize-handle">
                <div class="sidebar-resize-indicator"></div>
            </div>
        </nav>

        <div id="mdbook-page-wrapper" class="page-wrapper">

            <!-- Cross-manual switcher: persistent links to every
                 manual in this HOL doc site (Description, Tutorial,
                 Reference) and a Home link to the top-level lander.
                 Sits above the per-book menu-bar so readers never
                 lose sight of sibling manuals.  Lives OUTSIDE .page
                 because .page applies a negative top margin to slide
                 content under the sticky menu-bar; placing the
                 switcher there would hide it under the menu-bar.

                 The current-manual highlight is set by JS that
                 matches the URL path segment against the link
                 targets, since mdbook's Handlebars context has no
                 `eq` helper to compare against `book_title`. -->
            <div id="hol-manual-switcher" class="hol-manual-switcher">
                <a href="{{ path_to_root }}../index.html" data-hol-home>Home</a>
                <span class="sep" aria-hidden="true">·</span>
                <a href="{{ path_to_root }}../Description/" data-hol-manual="Description">Description</a>
                <a href="{{ path_to_root }}../Tutorial/" data-hol-manual="Tutorial">Tutorial</a>
                <a href="{{ path_to_root }}../Reference/" data-hol-manual="Reference">Reference</a>
            </div>
            <script>
                (function () {
                    var books = (window.HOL_MANUALS &&
                                 window.HOL_MANUALS.books) ||
                                ['Description', 'Tutorial', 'Reference'];
                    var segments = window.location.pathname.split('/');
                    var current = null;
                    for (var i = 0; i < segments.length; i++) {
                        if (books.indexOf(segments[i]) !== -1) {
                            current = segments[i];
                            break;
                        }
                    }
                    if (current) {
                        var match = document.querySelector(
                            '#hol-manual-switcher a[data-hol-manual="' +
                            current + '"]');
                        if (match) match.classList.add('current');
                        /* Tag <body> with the current book so CSS can
                           opt out of features per-book.  Reference's
                           1,613-entry sidebar has no useful section
                           numbering -- the entries are looked up by
                           name, not by sequence -- so custom.css
                           hides the auto-generated `<strong>N.M.</strong>`
                           and lets normal list bullets do the job. */
                        document.body.classList.add(
                            'hol-book-' + current.toLowerCase());
                    }
                })();
            </script>

            <div class="page">
                {{> header}}
                <div id="mdbook-menu-bar-hover-placeholder"></div>
                <div id="mdbook-menu-bar" class="menu-bar sticky">
                    <div class="left-buttons">
                        <label id="mdbook-sidebar-toggle" class="icon-button" for="mdbook-sidebar-toggle-anchor" title="Toggle Table of Contents" aria-label="Toggle Table of Contents" aria-controls="mdbook-sidebar">
                            {{fa "solid" "bars"}}
                        </label>
                        <button id="mdbook-theme-toggle" class="icon-button" type="button" title="Change theme" aria-label="Change theme" aria-haspopup="true" aria-expanded="false" aria-controls="mdbook-theme-list">
                            {{fa "solid" "paintbrush"}}
                        </button>
                        <ul id="mdbook-theme-list" class="theme-popup" aria-label="Themes" role="menu">
                            <li role="none"><button role="menuitem" class="theme" id="mdbook-theme-default_theme">Auto</button></li>
                            <li role="none"><button role="menuitem" class="theme" id="mdbook-theme-light">Light</button></li>
                            <li role="none"><button role="menuitem" class="theme" id="mdbook-theme-rust">Rust</button></li>
                            <li role="none"><button role="menuitem" class="theme" id="mdbook-theme-coal">Coal</button></li>
                            <li role="none"><button role="menuitem" class="theme" id="mdbook-theme-navy">Navy</button></li>
                            <li role="none"><button role="menuitem" class="theme" id="mdbook-theme-ayu">Ayu</button></li>
                        </ul>
                        {{#if search_enabled}}
                        <button id="mdbook-search-toggle" class="icon-button" type="button" title="Search (`/`)" aria-label="Toggle Searchbar" aria-expanded="false" aria-keyshortcuts="/ s" aria-controls="mdbook-searchbar">
                            {{fa "solid" "magnifying-glass"}}
                        </button>
                        {{/if}}
                    </div>

                    <h1 class="menu-title">{{ book_title }}</h1>

                    <div class="right-buttons">
                        {{#if print_enable}}
                        <a href="{{ path_to_root }}print.html" title="Print this book" aria-label="Print this book">
                            {{fa "solid" "print" "print-button"}}
                        </a>
                        {{/if}}
                        {{#if git_repository_url}}
                        <a href="{{git_repository_url}}" title="Git repository" aria-label="Git repository">
                            {{fa git_repository_icon_class git_repository_icon "git-repository-button"}}
                        </a>
                        {{/if}}
                        {{#if git_repository_edit_url}}
                        <a href="{{git_repository_edit_url}}" title="Suggest an edit" aria-label="Suggest an edit" rel="edit">
                            {{fa "solid" "pencil" "git-edit-button"}}
                        </a>
                        {{/if}}

                    </div>
                </div>

                {{#if search_enabled}}
                <div id="mdbook-search-wrapper" class="hidden">
                    <form id="mdbook-searchbar-outer" class="searchbar-outer">
                        <div class="search-wrapper">
                            <input type="search" id="mdbook-searchbar" name="searchbar" placeholder="Search all manuals ..." aria-controls="mdbook-searchresults-outer" aria-describedby="searchresults-header">
                            <div class="spinner-wrapper">
                                {{fa "solid" "spinner" "fa-spin"}}
                            </div>
                        </div>
                    </form>
                    <div id="mdbook-searchresults-outer" class="searchresults-outer hidden">
                        <div id="mdbook-searchresults-header" class="searchresults-header"></div>
                        <ul id="mdbook-searchresults">
                        </ul>
                    </div>
                </div>
                {{/if}}

                <!-- Apply ARIA attributes after the sidebar and the sidebar toggle button are added to the DOM -->
                <script>
                    document.getElementById('mdbook-sidebar-toggle').setAttribute('aria-expanded', sidebar === 'visible');
                    document.getElementById('mdbook-sidebar').setAttribute('aria-hidden', sidebar !== 'visible');
                    Array.from(document.querySelectorAll('#mdbook-sidebar a')).forEach(function(link) {
                        link.setAttribute('tabIndex', sidebar === 'visible' ? 0 : -1);
                    });
                </script>

                <div id="mdbook-content" class="content">
                    <main>
                        {{{ content }}}
                    </main>

                    <nav class="nav-wrapper" aria-label="Page navigation">
                        <!-- Mobile navigation buttons -->
                        {{#if previous}}
                            <a rel="prev" href="{{ path_to_root }}{{previous.link}}" class="mobile-nav-chapters previous" title="Previous chapter" aria-label="Previous chapter" aria-keyshortcuts="Left">
                                {{fa "solid" "angle-left"}}
                            </a>
                        {{/if}}

                        {{#if next}}
                            <a rel="next prefetch" href="{{ path_to_root }}{{next.link}}" class="mobile-nav-chapters next" title="Next chapter" aria-label="Next chapter" aria-keyshortcuts="Right">
                                {{fa "solid" "angle-right"}}
                            </a>
                        {{/if}}

                        <div style="clear: both"></div>
                    </nav>
                </div>
            </div>

            <nav class="nav-wide-wrapper" aria-label="Page navigation">
                {{#if previous}}
                    <a rel="prev" href="{{ path_to_root }}{{previous.link}}" class="nav-chapters previous" title="Previous chapter" aria-label="Previous chapter" aria-keyshortcuts="Left">
                        {{fa "solid" "angle-left"}}
                    </a>
                {{/if}}

                {{#if next}}
                    <a rel="next prefetch" href="{{ path_to_root }}{{next.link}}" class="nav-chapters next" title="Next chapter" aria-label="Next chapter" aria-keyshortcuts="Right">
                        {{fa "solid" "angle-right"}}
                    </a>
                {{/if}}
            </nav>

        </div>

        {{#if live_reload_endpoint}}
        <!-- Livereload script (if served using the cli tool) -->
        <script>
            const wsProtocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
            const wsAddress = wsProtocol + "//" + location.host + "/" + "{{{live_reload_endpoint}}}";
            const socket = new WebSocket(wsAddress);
            socket.onmessage = function (event) {
                if (event.data === "reload") {
                    socket.close();
                    location.reload();
                }
            };

            window.onbeforeunload = function() {
                socket.close();
            }
        </script>
        {{/if}}

        {{#if google_analytics}}
        <!-- Google Analytics Tag -->
        <script>
            const localAddrs = ["localhost", "127.0.0.1", ""];

            // make sure we don't activate google analytics if the developer is
            // inspecting the book locally...
            if (localAddrs.indexOf(document.location.hostname) === -1) {
                (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
                (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
                m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
                })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');

                ga('create', '{{google_analytics}}', 'auto');
                ga('send', 'pageview');
            }
        </script>
        {{/if}}

        {{#if playground_line_numbers}}
        <script>
            window.playground_line_numbers = true;
        </script>
        {{/if}}

        {{#if playground_copyable}}
        <script>
            window.playground_copyable = true;
        </script>
        {{/if}}

        {{#if playground_js}}
        <script src="{{ resource "ace.js" }}"></script>
        <script src="{{ resource "mode-rust.js" }}"></script>
        <script src="{{ resource "editor.js" }}"></script>
        <script src="{{ resource "theme-dawn.js" }}"></script>
        <script src="{{ resource "theme-tomorrow_night.js" }}"></script>
        {{/if}}

        {{#if search_js}}
        <script src="{{ resource "elasticlunr.min.js" }}"></script>
        <script src="{{ resource "mark.min.js" }}"></script>
        <!-- mdbook's bundled searcher.js is deliberately not loaded
             here.  Cross-book search needs the replacement at
             Manual/theme/hol-searcher.js, which each book.toml lists
             as `[output.html] additional-js = ["hol-searcher.js"]`
             so mdbook copies it into the per-book output and emits
             its own <script> tag for it. -->
        {{/if}}

        <script src="{{ resource "clipboard.min.js" }}"></script>
        <script src="{{ resource "highlight.js" }}"></script>
        <script src="{{ resource "book.js" }}"></script>

        <!-- Custom JS scripts -->
        {{#each additional_js}}
        <script src="{{ resource this}}"></script>
        {{/each}}

        {{#if is_print}}
        {{#if mathjax_support}}
        <script>
        window.addEventListener('load', function() {
            MathJax.Hub.Register.StartupHook('End', function() {
                window.setTimeout(window.print, 100);
            });
        });
        </script>
        {{else}}
        <script>
        window.addEventListener('load', function() {
            window.setTimeout(window.print, 100);
        });
        </script>
        {{/if}}
        {{/if}}

        {{#if fragment_map}}
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const fragmentMap =
                    {{{fragment_map}}}
                ;
                const target = fragmentMap[window.location.hash];
                if (target) {
                    let url = new URL(target, window.location.href);
                    window.location.replace(url.href);
                }
            });
        </script>
        {{/if}}

    </div>
    </body>
</html>
