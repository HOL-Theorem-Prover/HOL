INCLUDES = ../Tools ../Reference ../../examples/probability \
           $(HOLDIR)/src/integer $(HOLDIR)/src/sort \
           $(HOLDIR)/src/pred_set/src/more_theories \
           $(HOLDIR)/src/num/theories/cv_compute/automation

# Cross-manual labels.tsv prereq list for the mdbook target.
# See Manual/mdbook.mk for MANUALS / SIBLING_LABELS.
THIS = Description
include ../mdbook.mk

# Pull CHAPTER_STEMS in from a generated chapter-stems.mk so
# TEX_CORES tracks chapters.txt (both top-level chapters and
# nested sub-files) automatically.  The .mk is built by the rule
# below from gen_chap_lists; on a fresh checkout run
# `Holmake chapter-stems.mk' once before the PDF or mdbook
# targets (sinclude lets that bootstrap step succeed).
sinclude chapter-stems.mk
$(if $(CHAPTER_STEMS),,\
  $(warning chapter-stems.mk not yet built; \
            run `Holmake chapter-stems.mk' first))

TEX_CORES = description title preface $(CHAPTER_STEMS)

TEX_SOURCES = ../LaTeX/ack.tex ../LaTeX/commands.tex \
              chapters-include.tex book-title.tex \
              $(patsubst %,%.tex,$(TEX_CORES))

PS_ROOT = ../Tools/polyscripter
PS_STUFF =  $(PS_ROOT) ../Tools/umap
PS_NOUMAP = $(PS_ROOT) -md < $< > $@

# pandoc invocation for the .md -> .tex stage.  The same command
# serves both top-level chapter .smd files (which start with a
# `# Chapter Title` H1 -> \chapter{}) and nested sub-file .smd
# files (which start at `## Section Title` H2 -> \section{}, so
# they slot into the parent chapter's \input{<stem>}).
PANDOC_MD = pandoc --top-level-division=chapter --table-caption-position=below --lua-filter=../Tools/pdf-macros.lua -t latex $< > $@

.PHONY: all mdbook

all: description.pdf

# All .smd files (chapters and sub-files alike); pick them up
# automatically so adding a new .smd file doesn't require a
# Holmakefile edit just to wire its H1/H2/H3 entries into
# SUMMARY.md and its theory-build deps into mdbook's prereq
# chain.
SMDS = $(wildcard *.smd)
SMD_MDS = $(patsubst %.smd,%.md,$(SMDS))

# SVG renderings of the chapter figures, for the mdbook side.  The
# PDF side picks up the .mps / .pdf originals as usual.
SVG_FIGS = figs/0.svg figs/1.svg \
           figs/lsl.svg figs/lsr.svg figs/asr.svg \
           figs/ror.svg figs/rrx.svg

# MetaPost .mps -> .svg via mptopdf + pdftocairo, then pre-built
# .pdf -> .svg directly.  Both use cross-directory pattern rules:
# the literal `figs/' prefix scopes each pattern to the figures
# subdirectory, so unrelated .svg or .mps files elsewhere don't
# get caught.  mptopdf writes <name>-mps.pdf in cwd; clean that
# up after extracting the SVG.
figs/%.svg: figs/%.mps
	cd figs && mptopdf $*.mps
	pdftocairo -svg figs/$*-mps.pdf $@
	rm -f figs/$*-mps.pdf figs/$*.log

figs/%.svg: figs/%.pdf
	pdftocairo -svg $< $@

# Build the mdbook output for the chapters listed in SUMMARY.md;
# afterwards, scan the rendered HTML for raw-LaTeX leak patterns
# that have caused mdbook regressions before (see `smdpp
# check-html`).  The smdpp preprocessor is invoked dynamically by
# mdbook (see book.toml).
#
# `mdbook build` invokes smdpp which polyscripter-runs each .smd
# in-memory; the per-chapter .md rules below carry the theory-build
# dependencies smdpp's runtime `load "X"` calls need (e.g. math.md
# depends on `examples/probability/large_numberTheory.uo`).
# Depending on $(SMD_MDS) ensures Holmake builds those .uo files
# before mdbook runs, the same way description.pdf gets them via
# $(TEX_SOURCES).
# `mdbook` is a recipe-less PHONY alias for the real file target
# below: it just lets the per-manual `Holmake mdbook` (and the
# aggregator's Description/mdbook) name stand while the actual work
# is gated on `../book/Description/index.html`'s mtime, so re-runs
# with no source changes are no-ops instead of re-invoking mdbook
# and the post-build checks unconditionally.
mdbook: ../book/Description/index.html

../book/Description/index.html: ../Tools/smdpp SUMMARY.md \
        $(SMD_MDS) \
        $(SVG_FIGS) references.md cite-labels.tsv \
        ../Reference/entries.list \
        labels.tsv $(SIBLING_LABELS)
	mdbook build
	# Stable searchindex.js -> searchindex-<hash>.js symlink: the
	# cross-book searcher loads sibling indices from `../<Book>/
	# searchindex.js`, but mdbook hashes the actual filename
	# whenever content changes.  Resolve the hash here.
	cd ../book/Description && \
	  ln -sf $$(ls searchindex-*.js | head -1) searchindex.js
	../Tools/smdpp check-html ../book/Description
	../Tools/smdpp check-refs ../book/Description
	../Tools/smdpp check-links ../book/Description

# Scan-only label dump for cross-book `\ref{Book:label}` resolution.
# Walks SUMMARY.md + chapter sources without invoking polyscripter,
# so it's fast (~1s) and is built as a prereq of every manual's
# mdbook target (own + siblings) before anything slow runs.
labels.tsv: ../Tools/smdpp SUMMARY.md $(SMDS)
	../Tools/smdpp dump-labels .

# Render the bibliography chapter and the per-call-site cite label
# table in one shot, via pandoc citeproc.  Both outputs share a
# single `smdpp render-bib` invocation: references.md is the mdbook
# chapter wrapping the rendered bibliography, and cite-labels.tsv is
# smdpp's preprocessor-time lookup for substituting \cite{...} calls
# in chapter content.  The PDF path doesn't use either -- natbib's
# \bibliography{description} produces the bibliography directly.
CSL = ../Tools/csl/chicago-author-date.csl
references.md cite-labels.tsv: description.bib $(CSL) $(SMDS) ../Tools/smdpp
	../Tools/smdpp render-bib description.bib $(CSL) $(SMDS)

# SUMMARY.md and chapters-include.tex are generated from
# chapters.txt by Manual/Tools/gen_chap_lists.  chapters.txt
# is the canonical chapter ordering for the manual; top-level
# (un-indented) entries are chapters and indented entries are
# their nested sub-files (built with $(PANDOC_SEC) so their H1
# becomes \section{} inside the parent's \input).  The generator
# extracts mdbook chapter titles + sub-entries from each .smd's
# H1/H2/H3 headings, weaves in nested sub-file links at the
# position of each `\input{<stem>}` in the parent .smd, and
# emits `\include{stem}` lines for every top-level stem only.

SUMMARY.md: ../Tools/gen_chap_lists chapters.txt book.toml $(SMDS)
	../Tools/gen_chap_lists summary \
	   "$$(awk -F\" '/^title/ {print $$2; exit}' book.toml)" > $@

chapters-include.tex: ../Tools/gen_chap_lists chapters.txt
	../Tools/gen_chap_lists latex-include > $@

chapter-stems.mk: ../Tools/gen_chap_lists chapters.txt
	../Tools/gen_chap_lists stems > $@

# Generate a one-line LaTeX macro file whose body is the book
# title from book.toml; title.tex and description.tex (via
# \HOLbookTitle) consume it.  Keeps the PDF cover and the
# hyperref pdftitle in sync with the mdbook title automatically.
book-title.tex: book.toml
	printf '\\providecommand{\\HOLbookTitle}{%s}\n' \
	   "$$(awk -F\" '/^title/ {print $$2; exit}' book.toml)" > $@

# latexmk-side flags:
#   -bibtex: this latexmk (4.79) doesn't auto-invoke bibtex from
#     the .aux's \bibdata line on its own; the explicit flag forces
#     it through.
#   -f: pdflatex returns exit 1 on natbib warnings about undefined
#     citations in early passes, which without -f makes latexmk
#     abort the loop; we treat the actual PDF's existence as the
#     success signal.
# Trailing pdflatex pass: latexmk's convergence loop sometimes
# stops one pass too early when the second bibtex run produces
# the same .bbl as the first -- but pdflatex still needs another
# pass to incorporate the \bibcite entries it has only just
# written to its own .aux for early-document citations.
description.pdf: $(TEX_SOURCES)
	rm -f $@; \
	latexmk -pdf -bibtex -f -interaction=nonstopmode description; \
	pdflatex -interaction=nonstopmode description > /dev/null; \
	test -s $@

# Pattern rules for the per-chapter .smd -> .md -> .tex pipeline.
# Hand-rolled .tex front matter (description.tex, title.tex,
# preface.tex) is safe: Holmake skips pattern rules whose prereqs
# don't exist (see misc.smd's pattern-rule applicability note).
%.md: %.smd
	$(PS_NOUMAP)

%.tex: %.md ../Tools/pdf-macros.lua
	$(PANDOC_MD)

# $(PS_STUFF) lives in ../Tools/ and is only built on demand, so the
# pattern rule's applicability check (local rules + files only)
# would reject %.md before ../Tools/polyscripter exists.  Declare it
# as a recipe-less extra prereq on every .md, leaving the pattern
# recipe to apply.
$(SMD_MDS): $(PS_STUFF)

# Per-chapter extra prerequisites: theory-build deps or side files
# polyscripter reads from a chapter's .smd via `##use`.  Recipe-less
# rules slot in on top of the pattern rule above (see "additional
# prerequisites" under pattern rules in misc.smd).
theories.md: $(dprot $(HOLDIR)/src/real/realTheory.uo) \
             $(dprot $(HOLDIR)/src/integer/integerTheory.uo) \
             $(dprot $(HOLDIR)/src/real/real_sigmaTheory.uo) \
             $(dprot $(HOLDIR)/src/real/analysis/real_topologyTheory.uo) \
             $(dprot $(SIGOBJ)/iterateTheory.uo)

math.md: $(dprot $(HOLDIR)/src/probability/probabilityTheory.uo) \
         $(dprot $(HOLDIR)/src/probability/lebesgue_measureTheory.uo) \
         $(dprot $(HOLDIR)/examples/probability/large_numberTheory.uo) \
         $(dprot $(HOLDIR)/src/pred_set/src/more_theories/ordinalTheory.uo)

libraries.md: $(dprot $(HOLDIR)/src/integer/integerTheory.uo) \
              $(dprot $(HOLDIR)/src/sort/sortingTheory.uo) \
              $(dprot $(HOLDIR)/src/num/theories/cv_compute/automation/cv_transLib.uo) \
              $(dprot $(HOLDIR)/src/num/theories/cv_compute/automation/cv_stdTheory.uo)

HolSat.md: zchaff.cnf

# This builds figs/0.mps, figs/1.mps, ...
figures:
	mpost -mem=metafun -tex=latex figure.mp

EXTRA_CLEANS = $(SMD_MDS) $(patsubst %.smd,%.tex,$(SMDS)) \
               description.pdf \
               $(patsubst %,%.aux,$(TEX_CORES)) \
               description.log description.out \
               description.toc description.fls description.idx description.ilg \
               description.ind description.blg description.bbl \
               description.fdb_latexmk \
               chapters-include.tex chapter-stems.mk \
               book-title.tex SUMMARY.md \
               references.md cite-labels.tsv labels.tsv \
               $(SVG_FIGS) \
               ../book/Description/
