PS_COMMAND = $(PS_STUFF) < $< > $@
PS_NOUMAP = $(PS_ROOT) -md < $< > $@

# pandoc invocation for the .md -> .tex stage.  The same command
# serves both top-level chapter .smd files (which start with a
# `# Chapter Title` H1 -> \chapter{}) and nested sub-file .smd
# files (which start at `## Section Title` H2 -> \section{}, so
# they slot into the parent chapter's \input{<stem>}).
PANDOC_MD = pandoc --top-level-division=chapter --table-caption-position=below --lua-filter=pdf-macros.lua -t latex $< > $@

.PHONY: all mdbook mdbook-serve

all: description.pdf

# All .smd files (chapters and sub-files alike); pick them up
# automatically so adding a new .smd file doesn't require a
# Holmakefile edit just to wire its H1/H2/H3 entries into
# SUMMARY.md and its theory-build deps into mdbook's prereq
# chain.
SMDS = $(wildcard *.smd)
SMD_MDS = $(patsubst %.smd,%.md,$(SMDS))

# Build the mdbook output for the chapters listed in SUMMARY.md;
# afterwards, scan the rendered HTML for raw-LaTeX leak patterns
# that have caused mdbook regressions before (see
# mdbook-check.sh).  The smdpp preprocessor is invoked dynamically
# by mdbook (see book.toml).
#
# `mdbook build` invokes smdpp which polyscripter-runs each .smd
# in-memory; the per-chapter .md rules below carry the theory-build
# dependencies smdpp's runtime `load "X"` calls need (e.g. math.md
# depends on `examples/probability/large_numberTheory.uo`).
# Depending on $(SMD_MDS) ensures Holmake builds those .uo files
# before mdbook runs, the same way description.pdf gets them via
# $(TEX_SOURCES).
mdbook: ../Tools/smdpp SUMMARY.md ../Tools/mdbook-check.sh $(SMD_MDS)
	mdbook build
	../Tools/mdbook-check.sh ../book/Description
	../Tools/smdpp check-refs ../book/Description

# SUMMARY.md and chapters-include.tex are generated from
# chapters.txt by Manual/Tools/gen_chap_lists.  chapters.txt
# is the canonical chapter ordering for the manual; top-level
# (un-indented) entries are chapters and indented entries are
# their nested sub-files (built with $(PANDOC_SEC) so their H1
# becomes \section{} inside the parent's \input).  The generator
# extracts mdbook chapter titles + sub-entries from each .smd's
# H1/H2/H3 headings, weaves in nested sub-file links at the
# position of each `\input{<stem>}` in the parent .smd, and
# emits `\include{stem}` lines for every top-level stem only.

SUMMARY.md: ../Tools/gen_chap_lists chapters.txt $(SMDS)
	../Tools/gen_chap_lists summary > $@

chapters-include.tex: ../Tools/gen_chap_lists chapters.txt
	../Tools/gen_chap_lists latex-include > $@

# Convenience: serve the book locally at http://127.0.0.1:3000/.
# Live-reloads when .smd / theme / book.toml change.  Detaches into the
# background; pass LOG=1 to capture the server's stdout/stderr to
# mdbook-serve.log here, or LOG=<path> for a custom location.
mdbook-serve: ../Tools/smdpp
	@msg() { { echo "$$1" >/dev/tty; } 2>/dev/null || echo "$$1" >&2; }; \
	 if lsof -ti :3000 >/dev/null 2>&1; then \
	   msg "Port 3000 already in use; stop the existing server first:"; \
	   msg "  pkill -f 'mdbook serve'  (or: lsof -ti :3000 | xargs kill)"; \
	   exit 1; \
	 fi; \
	 logfile="$(LOG)"; \
	 [ "$$logfile" = 1 ] && logfile=mdbook-serve.log; \
	 [ -z "$$logfile" ] && logfile=/dev/null; \
	 (mdbook serve --hostname 127.0.0.1 --port 3000 \
	    >"$$logfile" 2>&1 &); \
	 msg "mdbook serving at http://127.0.0.1:3000/"; \
	 [ "$$logfile" != /dev/null ] && msg "log: $$(pwd)/$$logfile"; \
	 msg "stop: pkill -f 'mdbook serve'"

