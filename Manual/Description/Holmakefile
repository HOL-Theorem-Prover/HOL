INCLUDES = ../Tools ../../examples/probability $(HOLDIR)/src/integer

TEX_CORES = description title preface system conv drules tactics \
	theories math definitions libraries misc HolSat PatternMatchesLib \
        enumfset simplifier latex-munger modern-syntax-chapter advanced_tactics \
        suspension-resumption-subsection

TEX_SOURCES = ../LaTeX/ack.tex ../LaTeX/commands.tex $(patsubst %,%.tex,$(TEX_CORES))

PS_ROOT = ../Tools/polyscripter
PS_STUFF =  $(PS_ROOT) ../Tools/umap
PS_COMMAND = $(PS_STUFF) < $< > $@
PS_NOUMAP = $(PS_ROOT) < $< > $@

.PHONY: all mdbook mdbook-serve

all: system.pdf system.html drules.pdf drules.html description.pdf

# Build the mdbook output for the chapters listed in SUMMARY.md.
# The smdpp preprocessor is invoked dynamically by mdbook (see
# book.toml); the output goes to ../book/Description.
mdbook: ../Tools/smdpp
	mdbook build

# Convenience: serve the book locally at http://127.0.0.1:3000/.
# Live-reloads when .smd / theme / book.toml change.  Detaches into the
# background; pass LOG=1 to capture the server's stdout/stderr to
# mdbook-serve.log here, or LOG=<path> for a custom location.
mdbook-serve: ../Tools/smdpp
	@msg() { { echo "$$1" >/dev/tty; } 2>/dev/null || echo "$$1" >&2; }; \
	 if lsof -ti :3000 >/dev/null 2>&1; then \
	   msg "Port 3000 already in use; stop the existing server first:"; \
	   msg "  pkill -f 'mdbook serve'  (or: lsof -ti :3000 | xargs kill)"; \
	   exit 1; \
	 fi; \
	 logfile="$(LOG)"; \
	 [ "$$logfile" = 1 ] && logfile=mdbook-serve.log; \
	 [ -z "$$logfile" ] && logfile=/dev/null; \
	 (mdbook serve --hostname 127.0.0.1 --port 3000 \
	    >"$$logfile" 2>&1 &); \
	 msg "mdbook serving at http://127.0.0.1:3000/"; \
	 [ "$$logfile" != /dev/null ] && msg "log: $$(pwd)/$$logfile"; \
	 msg "stop: pkill -f 'mdbook serve'"

description.pdf: $(TEX_SOURCES)
	latexmk -pdf description

definitions.tex: definitions.stex $(PS_STUFF)
	$(PS_COMMAND)


advanced_tactics.tex: advanced_tactics.stex $(PS_STUFF)
	$(PS_COMMAND)

conv.tex: conv.stex $(PS_STUFF)
	$(PS_COMMAND)

drules.tex: drules.stex $(PS_STUFF)
	$(PS_COMMAND)

drules.md: drules.smd $(PS_STUFF)
	$(PS_NOUMAP)

drules.pdf: drules.md
	pandoc --top-level-division=chapter -o $@ $<

drules.html: drules.md
	pandoc -s -o $@ $<

tactics.tex: tactics.stex $(PS_STUFF)
	$(PS_COMMAND)

theories.tex: theories.stex $(PS_STUFF) $(dprot $(SIGOBJ)/realTheory.uo) \
	$(dprot $(HOLDIR)/src/integer/integerTheory.uo) \
	$(dprot $(HOLDIR)/src/real/real_sigmaTheory.uo) \
	$(dprot $(HOLDIR)/src/real/analysis/real_topologyTheory.uo) \
	$(dprot $(SIGOBJ)/iterateTheory.uo)
	$(PS_COMMAND)

math.tex: math.stex $(PS_STUFF) $(dprot $(SIGOBJ)/probabilityTheory.uo) \
    $(dprot $(SIGOBJ)/lebesgue_measureTheory.uo) \
	$(HOLDIR)/examples/probability/large_numberTheory.uo
	$(PS_COMMAND)

simplifier.tex: simplifier.stex $(PS_STUFF)
	$(PS_COMMAND)

PatternMatchesLib.tex: PatternMatchesLib.stex $(PS_STUFF)
	$(PS_COMMAND)

libraries.tex: libraries.stex $(PS_STUFF) $(dprot $(SIGOBJ)/integerTheory.uo)
	$(PS_COMMAND)

system.tex: system.stex $(PS_STUFF)
	$(PS_COMMAND)

system.md: system.smd $(PS_STUFF)
	$(PS_NOUMAP)

system.pdf: system.md
	pandoc --top-level-division=chapter -o $@ $<

system.html: system.md
	pandoc -s -o $@ $<

HolSat.tex: HolSat.stex $(PS_STUFF) zchaff.cnf
	$(PS_COMMAND)

modern-syntax.md: modern-syntax.smd $(PS_STUFF)
	$(PS_NOUMAP)

modern-syntax-chapter.tex: modern-syntax.md pdf-macros.lua
	(printf '\\chapter{\\texorpdfstring{\\HOL{} Source File Syntax}{HOL Source File Syntax}}\\label{chap:modern-syntax}\n' ; pandoc --top-level-division=chapter --table-caption-position=below --lua-filter=pdf-macros.lua -t latex $<) > $@

suspension-resumption.md: suspension-resumption.smd $(PS_STUFF)
	$(PS_NOUMAP)

suspension-resumption-subsection.tex: suspension-resumption.md pdf-macros.lua
	(printf '\\subsection{Proof Suspension and Resumption}\\label{sec:suspend-resume}\n' ; pandoc --top-level-division=section --table-caption-position=below --lua-filter=pdf-macros.lua -t latex $<) > $@

# This builds figs/0.mps, figs/1.mps, ...
figures:
	mpost -mem=metafun -tex=latex figure.mp

EXTRA_CLEANS = drules.tex tactics.tex theories.tex libraries.tex \
               PatternMatchesLib.tex HolSat.tex definitions.tex \
               system.tex system.md drules.md conv.tex math.tex \
               description.pdf mdbook-serve.log \
               $(patsubst %,%.aux,$(TEX_CORES)) \
	       description.log description.out \
               description.toc description.fls description.idx description.ilg \
               description.ind description.blg description.bbl \
	       description.fdb_latexmk modern-syntax.md modern-syntax-chapter.tex
