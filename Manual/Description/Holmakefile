system.tex: system.md pdf-macros.lua
	(printf '\\chapter{\\texorpdfstring{The \\HOL{} Logic in ML}{The HOL Logic in ML}}\\label{HOLsyschapter}\n' ; pandoc --top-level-division=chapter --table-caption-position=below --lua-filter=pdf-macros.lua -t latex $<) > $@

HolSat.tex: HolSat.stex $(PS_STUFF) zchaff.cnf
