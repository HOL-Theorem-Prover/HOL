INCLUDES = ../Tools

# Cross-manual labels.tsv prereq list for the mdbook target.
# See Manual/mdbook.mk for MANUALS / SIBLING_LABELS.
THIS = Interaction-emacs
include ../mdbook.mk

PS_ROOT = ../Tools/polyscripter
PS_STUFF = $(PS_ROOT) ../Tools/umap
PS_NOUMAP = $(PS_ROOT) -md < $< > $@

# Body-fragment output: pandoc emits the chapter content (H1, sections,
# code blocks, tables) as a snippet that manual.tex \input{}s.  No
# --standalone here -- pandoc's default LaTeX template would otherwise
# pull in lmodern.sty (often missing on minimal TeX installs), which
# the project's hand-written manuals don't depend on.
# --top-level-division=chapter turns each chapter .smd's H1 into a
# numbered \chapter{...} in the PDF (matches Description/Tutorial).
PANDOC_MD = pandoc --top-level-division=chapter \
            --lua-filter=../Tools/pdf-macros.lua -t latex $< > $@

.PHONY: all mdbook mdbook-serve

all: interaction-emacs.pdf

SMDS = $(wildcard *.smd)
SMD_MDS = $(patsubst %.smd,%.md,$(SMDS))

# Build the mdbook output and post-scan for raw-LaTeX leak patterns;
# the smdpp preprocessor is invoked dynamically by mdbook (see
# book.toml).  Cross-book \ref{Book:label} support requires every
# manual's labels.tsv on disk first; see Manual/Description/
# Holmakefile for the rationale.
# Recipe-less PHONY alias; the real gate is the file target below.
# See Manual/Description/Holmakefile for the rationale.
mdbook: ../book/Interaction-emacs/index.html

../book/Interaction-emacs/index.html: ../Tools/smdpp SUMMARY.md \
        $(SMD_MDS) \
        labels.tsv $(SIBLING_LABELS)
	mdbook build
	# Stable searchindex.js symlink for the cross-book searcher;
	# see Manual/Description/Holmakefile for the rationale.
	cd ../book/Interaction-emacs && \
	  ln -sf $$(ls searchindex-*.js | head -1) searchindex.js
	../Tools/smdpp check-html ../book/Interaction-emacs
	../Tools/smdpp check-refs ../book/Interaction-emacs
	../Tools/smdpp check-links ../book/Interaction-emacs

# Scan-only label dump for cross-book `\ref{Book:label}` resolution.
labels.tsv: ../Tools/smdpp SUMMARY.md $(SMDS)
	../Tools/smdpp dump-labels .

# SUMMARY.md generated from chapters.txt by gen_chap_lists; the H1
# at the top of the sidebar uses the book title from book.toml.
SUMMARY.md: ../Tools/gen_chap_lists chapters.txt book.toml $(SMDS)
	../Tools/gen_chap_lists summary \
	   "$$(awk -F\" '/^title/ {print $$2; exit}' book.toml)" > $@

# Convenience: serve the book locally at http://127.0.0.1:3004/.
# Port 3004 (after Description's 3000, Tutorial's 3001, the unified
# site's 3002, and Reference's 3003) so all manuals can be served
# side by side.
mdbook-serve: ../Tools/smdpp
	@msg() { { echo "$$1" >/dev/tty; } 2>/dev/null || echo "$$1" >&2; }; \
	 if lsof -ti :3004 >/dev/null 2>&1; then \
	   msg "Port 3004 already in use; stop the existing server first:"; \
	   msg "  pkill -f 'mdbook serve'  (or: lsof -ti :3004 | xargs kill)"; \
	   exit 1; \
	 fi; \
	 logfile="$(LOG)"; \
	 [ "$$logfile" = 1 ] && logfile=mdbook-serve.log; \
	 [ -z "$$logfile" ] && logfile=/dev/null; \
	 (mdbook serve --hostname 127.0.0.1 --port 3004 \
	    >"$$logfile" 2>&1 &); \
	 msg "mdbook serving at http://127.0.0.1:3004/"; \
	 [ "$$logfile" != /dev/null ] && msg "log: $$(pwd)/$$logfile"; \
	 msg "stop: pkill -f 'mdbook serve'"

# No bibliography, no citations: a plain pdflatex loop suffices.
# manual.tex is the hand-written wrapper that \input{}s each chapter
# .tex fragment (intro.tex, emacs.tex, ...) generated by pandoc from
# the corresponding .smd.  -f tolerates pdflatex returning non-zero
# from non-fatal package warnings so latexmk's convergence loop runs
# to completion.
# Trailing pdflatex: latexmk treats the non-zero exit from those
# warnings as a hard stop and may exit before the third pass that
# reads the .toc back into the printed PDF -- leaving an empty Table
# of Contents.  An explicit final pdflatex pass picks that up.
# Mirrors Manual/Description/Holmakefile's recipe for the same reason.
CHAPTER_TEXS = intro.tex emacs.tex search.tex tactics.tex reading.tex
interaction-emacs.pdf: manual.tex $(CHAPTER_TEXS) ../LaTeX/commands.tex
	rm -f $@ manual.pdf; \
	latexmk -pdf -f -interaction=nonstopmode manual; \
	pdflatex -interaction=nonstopmode manual > /dev/null; \
	test -s manual.pdf; \
	mv manual.pdf $@

# .smd -> .md (polyscripter, no umap) -> .tex (pandoc --standalone).
%.md: %.smd
	$(PS_NOUMAP)

%.tex: %.md ../Tools/pdf-macros.lua
	$(PANDOC_MD)

$(SMD_MDS): $(PS_STUFF)

EXTRA_CLEANS = $(SMD_MDS) $(patsubst %.smd,%.tex,$(SMDS)) \
               interaction-emacs.pdf mdbook-serve.log \
               manual.aux manual.log manual.out manual.toc \
               manual.fls manual.fdb_latexmk manual.pdf \
               $(patsubst %.tex,%.aux,$(CHAPTER_TEXS)) \
               SUMMARY.md labels.tsv \
               ../book/Interaction-emacs/
